{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/game/**",
              "ui_kits/the-hidden-hand/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|type|onClick|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, type, onClick, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|panic)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'panic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Consequence'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|text|key|ref|className|style|children)$/]",
        "message": "<Consequence> doesn't accept that prop. Declared props: kind, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='Consequence'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:gain|cost|threat|ritual)$/]",
        "message": "<Consequence> kind must be one of 'gain' | 'cost' | 'threat' | 'ritual'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConsequenceChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|children|style|key|ref|className|style|children)$/]",
        "message": "<ConsequenceChip> doesn't accept that prop. Declared props: kind, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConsequenceChip'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:gain|cost|threat|ritual)$/]",
        "message": "<ConsequenceChip> kind must be one of 'gain' | 'cost' | 'threat' | 'ritual'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|title|body|tags|open|onClick|style|key|ref|className|style|children)$/]",
        "message": "<EventCard> doesn't accept that prop. Declared props: kind, title, body, tags, open, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|style|key|ref|className|style|children)$/]",
        "message": "<Meter> doesn't accept that prop. Declared props: value, max, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PressureBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|style|key|ref|className|style|children)$/]",
        "message": "<PressureBar> doesn't accept that prop. Declared props: value, max, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResourceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:resource|style|key|ref|className|style|children)$/]",
        "message": "<ResourceCard> doesn't accept that prop. Declared props: resource, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResourceCard'] > JSXAttribute[name.name='resource'] > Literal[value!=/^(?:money|food|cultists|prisoners|relics|suspicion)$/]",
        "message": "<ResourceCard> resource must be one of 'money' | 'food' | 'cultists' | 'prisoners' | 'relics' | 'suspicion'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|label|value|title|style|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: glyph, label, value, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
